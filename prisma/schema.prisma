generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Model untuk menyimpan data Pengguna (Pelanggan & Admin)
model User {
  id        String  @id @default(cuid())
  name      String?
  username  String? @unique
  email     String  @unique
  password  String?
  phone     String?
  role      String  @default("user") // "user" (customer), "supplier" (seller), "admin"
  avatarUrl String?
  gender    String? // "male", "female", "other"
  birthDate DateTime?
  bio       String?
  isVerified Boolean @default(false)
  isSuspended Boolean @default(false)
  lastLoginAt DateTime?
  pin2FA    String? // PIN 6 digit untuk admin 2FA

  // Relasi
  supplier          Supplier?
  addresses         Address[]
  orders            Order[]
  orderInvoices     OrderInvoice[]
  voucherUsages     VoucherUsage[]
  behaviors         UserBehavior[]
  notificationPrefs UserNotificationPrefs?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// Model untuk Buku Alamat Pengguna
model Address {
  id            String  @id @default(cuid())
  label         String  @default("Rumah") // Rumah, Kantor, Toko
  recipientName String
  phone         String
  province      String
  city          String
  street        String
  zipCode       String
  isPrimary     Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Model untuk Supplier/Pabrik (B2B) — juga sebagai "Seller" di marketplace
model Supplier {
  id          String  @id @default(cuid())
  companyName String
  description String?
  verified    Boolean @default(false)

  // Performa Seller (untuk ranking)
  rating     Float @default(0) // Rating rata-rata toko (0-5)
  totalSales Int   @default(0) // Total penjualan keseluruhan

  // Profil B2B Lengkap
  logoUrl         String?
  bannerUrl       String?
  address         String?
  city            String?
  province        String?
  businessType    String? @default("Pabrik") // Pabrik, Distributor, Importir
  yearEstablished String?
  taxId           String? // NPWP
  allowCOD        Boolean @default(false)

  // Rekening Pencairan Dana
  bankName    String? // BCA, Mandiri, BRI, dll
  bankAccount String? // Nomor rekening
  bankHolder  String? // Nama pemilik rekening

  // Relasi ke User pemilik supplier ini
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  products Product[]
  orders   Order[]
  wallet   Wallet?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Dompet Virtual Supplier (Escrow Ledger)
model Wallet {
  id         String   @id @default(cuid())
  balance    Int      @default(0) // Saldo mengendap yang bisa ditarik
  supplierId String   @unique
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  transactions WalletTransaction[]
  withdrawals  WithdrawalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Mutasi Saldo
model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount      Int      // Positif (masuk), Negatif (keluar)
  type        String   // "order_revenue", "withdrawal", "refund", "adjustment"
  description String?
  referenceId String?  // ID Order atau ID Withdrawal

  createdAt DateTime @default(now())
}

// Pengajuan Penarikan Dana
model WithdrawalRequest {
  id          String   @id @default(cuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount      Int
  status      String   @default("pending") // "pending", "approved", "rejected", "completed"
  bankName    String
  bankAccount String
  bankHolder  String
  adminNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Kategori Produk untuk Toko
model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @default("")
  description String?
  icon        String? // Emoji atau SVG path untuk ikon kategori
  imageUrl    String? // URL gambar cover kategori

  products Product[] // Relasi 1 to Many

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Model untuk menyimpan data Produk LokalMart
model Product {
  id          String  @id @default(cuid())
  name        String
  description String
  price       Int
  stock       Int     @default(0)
  imageUrl    String?
  status      String  @default("active") // "active", "inactive", "pending_review", "rejected"

  // B2B Fields
  minOrder Int    @default(1)
  unit     String @default("Pieces") // e.g. "Pieces", "Sets", "Cartons"
  
  // Logistik Dasar
  weight   Int    @default(1000) // dalam Gram
  length   Int?   // dalam cm
  width    Int?   
  height   Int?

  // Pre-Order & Kustomisasi
  isPreOrder    Boolean @default(false)
  preOrderDays  Int?    // Waktu proses dalam hari
  customOptions Json?   // [{"name": "Ukuran", "options": [{"label": "XL", "priceDelta": 5000}]}]

  // Marketing & Monetisasi
  isSponsored   Boolean @default(false)

  // Kategori
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Supplier
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // Relasi
  variants       ProductVariant[]
  orderItems     OrderItem[]
  flashSaleItems FlashSaleItem[]
  metrics        ProductMetrics?
  eventProducts  EventProduct[]
  userBehaviors  UserBehavior[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@index([categoryId])
  @@index([status])
}

// ============================================================
// Product Variant — Varian Ukuran/Warna
// ============================================================
model ProductVariant {
  id        String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  name      String  // e.g. "Merah - XL"
  sku       String?
  price     Int?    // Jika null, gunakan harga dasar produk
  stock     Int     @default(0)
  color     String? // e.g. "Merah"
  size      String? // e.g. "XL"

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

// ============================================================
// Product Metrics — tracking performa setiap produk
// ============================================================
model ProductMetrics {
  id             String   @id @default(cuid())
  views          Int      @default(0)
  clicks         Int      @default(0)
  purchases      Int      @default(0)
  conversionRate Float    @default(0) // clicks→purchases ratio
  avgRating      Float    @default(0)
  totalRevenue   Int      @default(0)
  lastUpdated    DateTime @default(now()) @updatedAt

  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([views])
  @@index([purchases])
  @@index([conversionRate])
}

// ============================================================
// Event — kampanye/promo/flash sale fleksibel
// ============================================================
model Event {
  id        String   @id @default(cuid())
  name      String
  type      String // "flash_sale", "campaign", "seasonal", "clearance"
  startTime DateTime
  endTime   DateTime
  isActive  Boolean  @default(true)

  // Konfigurasi fleksibel (JSON)
  configJson Json?

  // AI-generated content
  aiTitle    String?
  aiSubtitle String?
  aiCta      String?

  products EventProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([startTime, endTime])
}

// ============================================================
// Event Products — produk yang ikut dalam event
// ============================================================
model EventProduct {
  id               String @id @default(cuid())
  discountPercent  Int    @default(0)
  featuredPosition Int    @default(0)

  eventId   String
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([eventId, productId])
  @@index([eventId])
  @@index([productId])
}

// ============================================================
// User Behavior — tracking aksi user untuk AI personalisasi
// ============================================================
model UserBehavior {
  id         String   @id @default(cuid())
  actionType String // "view", "click", "add_to_cart", "purchase", "wishlist", "search"
  metadata   Json?  // {"searchQuery": "sepatu", "source": "homepage"}
  timestamp  DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([productId])
  @@index([actionType])
  @@index([timestamp])
  @@index([userId, actionType])
}

// ============================================================
// Model-model yang sudah ada sebelumnya
// ============================================================

model OrderInvoice {
  id          String @id @default(cuid())
  totalAmount Int
  status      String @default("pending") // "pending", "awaiting_payment", "paid", "cancelled"
  
  shippingName     String?
  shippingPhone    String?
  shippingProvince String?
  shippingCity     String?
  shippingAddress  String?
  shippingZipCode  String?

  paymentMethod String?
  paymentToken  String?
  paymentUrl    String?

  voucherId      String?
  discountAmount Int     @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orders Order[] // Sub-Orders per toko

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Order adalah representasi pesanan per-Toko (Sub-Order)
model Order {
  id          String @id @default(cuid())
  totalAmount Int
  status      String @default("pending") // "pending", "packed", "shipped", "delivered", "completed", "cancelled"

  shippingMethod   String? // "Reguler", "Kargo"
  courier          String? // "JNE", "SICEPAT"
  resiNumber       String?
  shippingCost     Int     @default(0)

  invoiceId String?
  invoice   OrderInvoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  trackingHistory OrderTracking[]
  items           OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderTracking {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      String
  description String
  createdAt   DateTime @default(now())
}

model OrderItem {
  id       String @id @default(cuid())
  quantity Int
  price    Int

  selectedOptions Json?
  notes           String?

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

model FlashSale {
  id        String          @id @default(cuid())
  title     String
  startTime DateTime
  endTime   DateTime
  isActive  Boolean         @default(true)
  bannerUrl String?
  items     FlashSaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlashSaleItem {
  id            String    @id @default(cuid())
  flashSaleId   String
  flashSale     FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  discountPrice Int
  stock         Int
  sold          Int       @default(0)

  @@unique([flashSaleId, productId])
}

model Voucher {
  id          String         @id @default(cuid())
  code        String         @unique
  type        String
  value       Int
  minPurchase Int            @default(0)
  maxDiscount Int?
  usageLimit  Int            @default(100)
  usedCount   Int            @default(0)
  isPublic    Boolean        @default(false)
  startDate   DateTime
  endDate     DateTime
  usages      VoucherUsage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model VoucherUsage {
  id        String   @id @default(cuid())
  voucherId String
  voucher   Voucher  @relation(fields: [voucherId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  orderId   String?
  usedAt    DateTime @default(now())

  @@unique([voucherId, userId, orderId])
}

model Campaign {
  id       String  @id @default(cuid())
  title    String
  subtitle String?
  position String

  imageUrl  String?
  colorFrom String?
  colorTo   String?
  textColor String? @default("white")

  pageTitle   String?
  pageContent String? @db.Text

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  channel   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, code])
}

// Preferensi notifikasi user
model UserNotificationPrefs {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailOrder        Boolean @default(true)
  emailPromo        Boolean @default(true)
  emailSecurity     Boolean @default(true) // selalu aktif
  pushNotification  Boolean @default(false)

  updatedAt DateTime @updatedAt
}

// Modul Banner & CMS
model Banner {
  id          String   @id @default(cuid())
  title       String
  imageUrl    String
  targetUrl   String?
  position    Int      @default(0) // urutan tampil
  isActive    Boolean  @default(true)
  isPopup     Boolean  @default(false) // Jika true, tampil sebagai popup promo
  startDate   DateTime?
  endDate     DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// Admin Panel Models
// ============================================================

enum AdminRole {
  SUPERADMIN
  ADMIN
  MODERATOR
  FINANCE
}

model AdminUser {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      AdminRole @default(ADMIN)
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  logs      AdminActivityLog[]
}

model AdminActivityLog {
  id            String    @id @default(uuid())
  adminId       String
  action        String
  targetTable   String?
  targetId      String?
  oldData       String?
  newData       String?
  ipAddress     String?
  createdAt     DateTime  @default(now())

  admin         AdminUser @relation(fields: [adminId], references: [id])
}

// Konfigurasi Global Platform
model PlatformSetting {
  id                String   @id @default("global")
  commissionPercent Float    @default(5.0)
  updatedAt         DateTime @updatedAt
}


model NavigationMenu {
  id        String   @id @default(uuid())
  title     String
  iconUrl   String
  href      String
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
